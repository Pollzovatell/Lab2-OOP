import re
import unittest


class TextProcessor:
    def __init__(self, text, word_length):
        self.text = text
        self.word_length = word_length

    def is_consonant(self, char):
        vowels = "aeiouаеєиіїоуюяAEIOUАЕЄИІЇОУЮЯ"
        return char.isalpha() and char not in vowels

    def process_text(self):
        try:
            words = re.findall(r'\b\w+\b', self.text)

            result_words = []

            for word in words:
                if len(word) == self.word_length and self.is_consonant(word[0]):
                    continue
                result_words.append(word)

            return " ".join(result_words)

        except Exception as e:
            return f"Помилка: {e}"


class TestTextProcessor(unittest.TestCase):

    def test_remove_words_consonant(self):
        text = "Кіт біг по дорозі швидко"
        processor = TextProcessor(text, 3)
        result = processor.process_text()

        self.assertEqual(result, "по дорозі швидко")

    def test_keep_vowel_words(self):
        text = "Іра іде у школу"
        processor = TextProcessor(text, 3)
        result = processor.process_text()

        self.assertEqual(result, "Іра іде у школу")

    def test_mixed_case(self):
        text = "Dog cat apple sky"
        processor = TextProcessor(text, 3)
        result = processor.process_text()

        self.assertEqual(result, "apple")

    def test_empty_string(self):
        processor = TextProcessor("", 3)
        result = processor.process_text()
        self.assertEqual(result, "")

    def test_no_matches(self):
        text = "hello world"
        processor = TextProcessor(text, 10)
        result = processor.process_text()

        self.assertEqual(result, "hello world")



